generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Tenant {
  mongoId          String   @id @default(auto()) @map("_id") @db.ObjectId
  id               String   @unique
  name             String
  slug             String   @unique
  logo             String?
  countryCode      String
  currency         String
  vatRate          Float
  vatNumber        String?
  address          String
  phone            String
  email            String
  subscriptionPlan String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  validUntil       DateTime?
  invoiceFooter    String?
  primaryColor     String?
  adminPassword    String?
  kitchenPrinterName       String?
  kitchenPrinterConnection String?
  kitchenPrinterEnabled    Boolean? @default(false)
  kitchenAutoPrint         Boolean? @default(false)
  cashierPrinterName       String?
  cashierPrinterConnection String?
  cashierPrinterEnabled    Boolean? @default(false)
  cashierAutoPrint         Boolean? @default(false)
}

model Category {
  mongoId   String  @id @default(auto()) @map("_id") @db.ObjectId
  id        String  @unique
  tenantId  String
  name      String
  nameAr    String?
  icon      String?
  sortOrder Int     @default(1)
  isActive  Boolean @default(true)
}

model Order {
  mongoId        String   @id @default(auto()) @map("_id") @db.ObjectId
  id            String   @unique
  tenantId      String
  tableNumber   Int?
  waiterId      String?
  cashierId     String?
  status        String   @default("pending")
  subtotal      Float
  vatRate       Float
  vatAmount     Float
  total         Float
  paymentMethod String?
  isPaid        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  notes         String?
  invoiceNumber String?
  isQrOrder     Boolean  @default(false)
  customerName  String?
  customerPhone String?
  orderType     String?
  itemsJson     String   @default("[]")
}

model MenuItem {
  mongoId         String  @id @default(auto()) @map("_id") @db.ObjectId
  id              String  @unique
  tenantId        String
  categoryId      String
  name            String
  nameAr          String?
  description     String?
  descriptionAr   String?
  price           Float
  hasHalfPlate    Boolean @default(false)
  halfPlatePrice  Float?
  image           String?
  isAvailable     Boolean @default(true)
  preparationTime Int?
  calories        Int?
  isPopular       Boolean @default(false)
  isNew           Boolean @default(false)
}

model User {
  mongoId    String   @id @default(auto()) @map("_id") @db.ObjectId
  id         String   @unique
  tenantId   String
  name       String
  email      String
  password   String?
  role       String
  language   String   @default("en")
  isActive   Boolean  @default(true)
  hourlyRate Float?
  createdAt  DateTime @default(now())
}

model SyncQueue {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        String   @unique @default(uuid())
  entity    String   // e.g., "Order"
  entityId  String   // e.g., the Order ID
  operation String   // e.g., "CREATE", "UPDATE", "DELETE"
  payload   String   // JSON string of the data
  status    String   @default("PENDING") // "PENDING", "SYNCED", "FAILED"
  createdAt DateTime @default(now())
}
