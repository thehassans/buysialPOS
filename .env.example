# ============================================
# BuysialPOS Environment Configuration
# Copy this to .env.production on your server
# ============================================

# Database (SQLite - file-based, no server needed)
DATABASE_URL="file:./prisma/pos.db"

# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=BuysialPOS

# Database (if you add one later, e.g. PostgreSQL via Prisma)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# JWT / Auth secret (generate a strong random string)
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_URL=https://yourdomain.com

# Optional: Email (for notifications)
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=yourpassword

# Optional: Storage (for menu images in production)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=yourcloudname
# CLOUDINARY_API_KEY=yourkey
# CLOUDINARY_API_SECRET=yoursecret
